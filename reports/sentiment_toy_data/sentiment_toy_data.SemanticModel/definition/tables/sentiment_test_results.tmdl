	column confidence_score
		dataType: double
		lineageTag: f4a2b3c4-d5e6-f7a8-b9c0-d1e2f3a4b5e5
		summarizeBy: average
		sourceColumn: confidence_score

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column prediction_date
		dataType: dateTime
		formatString: General Date
		lineageTag: f5a2b3c4-d5e6-f7a8-b9c0-d1e2f3a4b5e6
		summarizeBy: none
		sourceColumn: prediction_date

		annotation SummarizationSetBy = Automatic

	column Year = YEAR('sentiment_test_results'[prediction_date])
